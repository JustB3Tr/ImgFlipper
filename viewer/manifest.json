{
  "name": "FlipViewer",
  "short_name": "Flip",
  "description": "View and create .flip dual-sided image files",
  "start_url": "./index.html",
  "display": "standalone",
  "background_color": "#09090b",
  "theme_color": "#6366f1",
  "orientation": "any",
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "application/x-flip-image": [".flip"]
      }
    }
  ],
  "categories": ["utilities", "productivity"]
}
